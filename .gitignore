# WingBuddy monorepo — Node/Next.js (client/ + server/)
# NOTE: no "lib/" entry — that Python pattern would ignore server/lib/.

# dependencies
**/node_modules/
/.pnp
.pnp.*

# next.js / build output
**/.next/
**/out/
**/build/
*.tsbuildinfo
next-env.d.ts

# test / coverage
**/coverage/

# env — never commit secrets; .env.example is allowed
.env
.env.*
!**/.env.example

# runtime data (in-memory store snapshots, if ever persisted)
data/

# vocal-bridge CLI credentials (never commit)
.vocal-bridge/
**/.vocal-bridge/

# build-time merge artifacts (copied from server/ — never commit these into client/)
client/app/api/
client/lib/access.ts
client/lib/brain.ts
client/lib/events.ts
client/lib/facilities.ts
client/lib/request-auth.ts
client/lib/sabre.ts
client/lib/session-store.ts
client/lib/translate.ts
client/lib/vocalbridge.ts
client/lib/withCors.ts
client/lib/__tests__/

# vercel / cloud
.vercel

# misc / OS / editors
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.idea/
.vscode/
