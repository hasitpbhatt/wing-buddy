# WingBuddy monorepo — Node/Next.js (client/ + server/)
# NOTE: no "lib/" entry — that Python pattern would ignore server/lib/.

# dependencies
**/node_modules/
/.pnp
.pnp.*

# next.js / build output
**/.next/
**/out/
**/build/
*.tsbuildinfo
next-env.d.ts

# test / coverage
**/coverage/

# env — never commit secrets; .env.example is allowed
.env
.env.*
!**/.env.example

# runtime data (in-memory store snapshots, if ever persisted)
data/

# vocal-bridge CLI credentials (never commit)
.vocal-bridge/
**/.vocal-bridge/

# vercel / cloud
.vercel

# misc / OS / editors
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.idea/
.vscode/
